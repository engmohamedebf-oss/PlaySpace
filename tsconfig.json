{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "target": "ES2021",
    "module": "ESNext",
    "jsx": "react-native",
    "allowJs": false,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "types": ["react", "react-native", "react-native-vector-icons"],
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}